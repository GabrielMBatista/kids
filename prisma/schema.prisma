// LetraFun — Prisma Schema
// Database: TiDB Cloud (MySQL-compatible)

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider     = "mysql"
  url          = env("DATABASE_URL")
  relationMode = "prisma"
}

// ─── Enums ───────────────────────────────────────────────────────────────────

enum AgeGroup {
  EXPLORER    // 3–5 anos
  ADVENTURER  // 6–7 anos
  CHALLENGER  // 8–10 anos
}

enum Rarity {
  COMMON
  UNCOMMON
  RARE
  EPIC
  LEGENDARY
}

enum StickerSource {
  GIPHY
  GEMINI
}

// ─── Models ──────────────────────────────────────────────────────────────────

model Parent {
  id        String   @id @default(cuid())
  email     String   @unique
  name      String
  password  String
  children  Child[]
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Child {
  id          String        @id @default(cuid())
  name        String
  avatar      String        @default("fox")
  ageGroup    AgeGroup
  xp          Int           @default(0)
  level       Int           @default(1)
  streak      Int           @default(0)
  lastPlayedAt DateTime?
  parent      Parent        @relation(fields: [parentId], references: [id])
  parentId    String
  stickers    ChildSticker[]
  sessions    GameSession[]
  createdAt   DateTime      @default(now())
  updatedAt   DateTime      @updatedAt

  @@index([parentId])
}

model Sticker {
  id        String        @id @default(cuid())
  name      String
  imageUrl  String        @db.LongText  // Giphy CDN URL, Vercel Blob URL or base64 data URL
  rarity    Rarity
  source    StickerSource
  album     String        // e.g. "Animais da Floresta"
  prompt    String?       @db.Text  // Gemini prompt used (GEMINI source only)
  themeId   String?
  theme     Theme?        @relation(fields: [themeId], references: [id])
  children  ChildSticker[]
  createdAt DateTime      @default(now())

  @@index([rarity])
  @@index([themeId])
}

model ChildSticker {
  id         String   @id @default(cuid())
  child      Child    @relation(fields: [childId], references: [id])
  childId    String
  sticker    Sticker  @relation(fields: [stickerId], references: [id])
  stickerId  String
  quantity   Int      @default(1)
  earnedAt   DateTime @default(now())

  @@unique([childId, stickerId])
  @@index([childId])
  @@index([stickerId])
}

model GameSession {
  id         String   @id @default(cuid())
  child      Child    @relation(fields: [childId], references: [id])
  childId    String
  gameType   String   // e.g. "letter-tap", "syllable-factory"
  pillar     String   // e.g. "LETTERS", "SYLLABLES"
  score      Int
  xpEarned   Int
  accuracy   Float    // 0.0–1.0
  duration   Int      // seconds
  playedAt   DateTime @default(now())

  @@index([childId])
  @@index([gameType])
}

model AudioCache {
  id        String   @id @default(cuid())
  text      String   @unique @db.VarChar(500)  // letter, syllable or word
  audioUrl  String   // ElevenLabs-generated, stored in Vercel Blob
  createdAt DateTime @default(now())
}

model MediaCache {
  id        String   @id @default(cuid())
  query     String   @unique @db.VarChar(200)
  imageUrl  String?
  videoUrl  String?
  source    String   // "pexels" | "pixabay"
  createdAt DateTime @default(now())
}

model Theme {
  id            String   @id @default(cuid())
  name          String   // e.g. "Mundo de Blocos"
  ageGroup      AgeGroup
  bgPrompt      String   @db.Text
  charPrompt    String   @db.Text
  stickerPrompt String   @db.Text
  bgImageUrl    String?
  charImageUrl  String?
  activeFrom    DateTime
  activeTo      DateTime
  stickers      Sticker[]
  createdAt     DateTime @default(now())

  @@index([ageGroup])
}
