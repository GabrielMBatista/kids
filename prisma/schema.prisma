generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider     = "mysql"
  url          = env("DATABASE_URL")
  relationMode = "prisma"
}

model Parent {
  id        String   @id @default(cuid())
  email     String   @unique
  name      String
  password  String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  children  Child[]
}

model Child {
  id           String         @id @default(cuid())
  name         String
  avatar       String         @default("fox")
  ageGroup     AgeGroup
  xp           Int            @default(0)
  level        Int            @default(1)
  streak       Int            @default(0)
  lastPlayedAt DateTime?
  parentId     String
  createdAt    DateTime       @default(now())
  updatedAt    DateTime       @updatedAt
  parent       Parent         @relation(fields: [parentId], references: [id])
  stickers     ChildSticker[]
  sessions     GameSession[]

  @@index([parentId])
}

model Sticker {
  id        String         @id @default(cuid())
  name      String
  imageUrl  String         @db.LongText
  rarity    Rarity
  source    StickerSource
  album     String
  prompt    String?        @db.Text
  themeId   String?
  createdAt DateTime       @default(now())
  theme     Theme?         @relation(fields: [themeId], references: [id])
  children  ChildSticker[]

  @@index([rarity])
  @@index([themeId])
}

model ChildSticker {
  id        String   @id @default(cuid())
  childId   String
  stickerId String
  quantity  Int      @default(1)
  earnedAt  DateTime @default(now())
  child     Child    @relation(fields: [childId], references: [id])
  sticker   Sticker  @relation(fields: [stickerId], references: [id])

  @@unique([childId, stickerId])
  @@index([childId])
  @@index([stickerId])
}

model GameSession {
  id       String   @id @default(cuid())
  childId  String
  gameType String
  pillar   String
  score    Int
  xpEarned Int
  accuracy Float
  duration Int
  playedAt DateTime @default(now())
  child    Child    @relation(fields: [childId], references: [id])

  @@index([childId])
  @@index([gameType])
}

model AudioCache {
  id        String   @id @default(cuid())
  text      String   @unique @db.VarChar(500)
  audioUrl  String
  createdAt DateTime @default(now())
}

model MediaCache {
  id        String   @id @default(cuid())
  query     String   @unique @db.VarChar(200)
  imageUrl  String?
  videoUrl  String?
  source    String
  createdAt DateTime @default(now())
}

model Theme {
  id            String    @id @default(cuid())
  name          String
  ageGroup      AgeGroup
  bgPrompt      String    @db.Text
  charPrompt    String    @db.Text
  stickerPrompt String    @db.Text
  bgImageUrl    String?
  charImageUrl  String?
  activeFrom    DateTime
  activeTo      DateTime
  createdAt     DateTime  @default(now())
  stickers      Sticker[]

  @@index([ageGroup])
}

enum AgeGroup {
  EXPLORER
  ADVENTURER
  CHALLENGER
}

enum Rarity {
  COMMON
  UNCOMMON
  RARE
  EPIC
  LEGENDARY
}

enum StickerSource {
  GIPHY
  GEMINI
}
